# InvoiceFlow Production Environment
# Copy to .env.production and fill in real values

# Application
APP_NAME=InvoiceFlow
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS

# Database
DATABASE_URL=postgresql+asyncpg://invoiceflow:CHANGE_ME@postgres:5432/invoiceflow
POSTGRES_USER=invoiceflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=invoiceflow

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=invoiceflow
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_CONFIDENCE_THRESHOLD=0.85

# CORS
CORS_ORIGINS=["https://yourdomain.com"]

# Email (IMAP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# FTP/SFTP
FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
FTP_REMOTE_DIR=/invoices/inbox
FTP_REMOTE_PROCESSED=/invoices/processed

# Compliance
COMPLIANCE_SANDBOX=true
PEPPOL_CUSTOMISATION_ID=urn:fdc:peppol.eu:2017:poacc:billing:3.0:extended.1:01
ZATCA_API_KEY=
ZATCA_API_SECRET=
BRAZIL_CNPJ=
INDIA_GSP_API_KEY=
INDIA_GSP_API_SECRET=
MX_PAC_API_KEY=
MX_PAC_API_SECRET=
ARCHIVE_PATH=/data/archives

# ERP Connectors
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
SAP_API_KEY=
SAP_API_SECRET=
ORACLE_API_KEY=
ORACLE_API_SECRET=

# Monitoring
GRAFANA_PASSWORD=admin
