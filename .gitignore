__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
celerybeat-schedule
celerybeat-schedule.dir/

