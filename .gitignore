postgres_data/
redis_data/
minio_data/

# ---------------- Agent tooling (regenerated locally) ----------------
# Project-level conventions are committed (CLAUDE.md, .opencode/.specify/, .claude/).
# These are regeneratable caches and indexes — safe to ignore.
.swarm/
.gitnexus/
.opencode/memory/
.opencode/node_modules/
.opencode/elf/
.infinit-graph.json
knowledge.md
plan/

# ---------------- Logs ----------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
