# InvoiceFlow Environment Configuration
# Copy to .env and fill in your values

# Application
APP_NAME=InvoiceFlow
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://invoiceflow:invoiceflow@postgres:5432/invoiceflow

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=invoiceflow
MINIO_SECURE=false

# JWT Auth
JWT_SECRET_KEY=jwt-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM Provider (claude or openai)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_CONFIDENCE_THRESHOLD=0.85

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Email (IMAP) — optional
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# FTP — optional
FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=

# SFTP — optional
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
